<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingEnd="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_otp_issuer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_main"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_otp_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_otp_code_area"
        android:layout_width="92dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_otp_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:letterSpacing="0.03"
            android:textColor="@color/primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_otp_copy_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/otp_copy_hint"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="42dp"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_otp_remaining"
            android:layout_width="40dp"
            android:layout_height="26dp"
            android:background="@drawable/bg_chip"
            android:gravity="center"
            android:textColor="@color/text_main"
            android:textSize="11sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progress_otp_remaining"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="38dp"
            android:layout_height="4dp"
            android:layout_marginTop="4dp"
            android:max="30" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_otp_next"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_otp_pin"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="☆"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btn_otp_edit"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="✎"
        android:textSize="15sp" />

    <Button
        android:id="@+id/btn_otp_delete"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="4dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="@string/otp_delete_short"
        android:textSize="12sp" />
</LinearLayout>
