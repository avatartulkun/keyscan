<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="14dp">

    <View
        android:layout_width="42dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="#C9CDD2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/home_generate"
        android:textColor="@color/text_main"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_input"
        android:layout_width="match_parent"
        android:layout_height="92dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_edit_text"
        android:elevation="1dp"
        android:gravity="top"
        android:hint="@string/qr_input_hint"
        android:inputType="textMultiLine|textUri"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        android:textSize="15sp" />

    <EditText
        android:id="@+id/et_qr_note"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_edit_text"
        android:elevation="1dp"
        android:hint="@string/qr_note_hint"
        android:inputType="text"
        android:textColor="@color/text_main"
        android:textColorHint="@color/text_hint"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_qr_style"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/qr_style_classic"
            android:textColor="#4A90D9" />

        <Button
            android:id="@+id/btn_qr_foreground"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/foreground_color"
            android:textColor="#4A90D9" />

        <Button
            android:id="@+id/btn_qr_background"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/background_color"
            android:textColor="#4A90D9" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_generate_qr"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:text="@string/generate_qr" />

    <FrameLayout
        android:layout_width="176dp"
        android:layout_height="176dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_preview"
        android:elevation="2dp"
        android:padding="8dp">

        <ImageView
            android:id="@+id/iv_qr_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/qr_preview" />

        <TextView
            android:id="@+id/tv_qr_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/qr_preview_placeholder"
            android:textColor="@color/text_hint"
            android:textSize="13sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_save_png"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/save_to_album" />

        <Button
            android:id="@+id/btn_save_record"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/save_to_record" />
    </LinearLayout>
</LinearLayout>


