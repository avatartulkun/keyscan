<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:background="@drawable/bg_card"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_history_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_main"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_history_meta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_history_remark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_history_toggle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="@string/show_short"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btn_history_copy"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="@string/copy"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btn_history_qr"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="▦"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_history_edit"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="✎"
        android:textSize="18sp" />

    <Button
        android:id="@+id/btn_history_delete"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="6dp"
        android:minWidth="0dp"
        android:padding="0dp"
        android:text="@string/delete"
        android:textSize="13sp" />
</LinearLayout>


