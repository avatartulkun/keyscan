<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/webdav_title"
            android:textColor="@color/text_main"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/webdav_desc"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/card_main_webdav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/row_main_webdav_title"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/main_webdav_title"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_main_webdav_arrow"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="⌃"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/et_webdav_url"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/webdav_url_hint"
                android:inputType="textUri"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/et_webdav_user"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/username_hint"
                android:inputType="text"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_hint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_webdav_pass"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/webdav_password_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_toggle_webdav_pass"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/click_show_password"
                    android:minWidth="40dp"
                    android:padding="0dp"
                    android:text="@string/show_short" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_backup_encryption_password"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/backup_encryption_password"
                    android:inputType="textPassword"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_toggle_backup_encryption_password"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/click_show_password"
                    android:minWidth="40dp"
                    android:padding="0dp"
                    android:text="@string/show_short" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_backup_password_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/backup_password_hint"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <CheckBox
                android:id="@+id/cb_independent_backup_password"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/independent_backup_password"
                android:textColor="@color/text_main" />

            <TextView
                android:id="@+id/tv_independent_backup_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/independent_backup_warning"
                android:textColor="@color/brand_orange"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_save_webdav_settings"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:text="@string/save_webdav_settings" />

            <Spinner
                android:id="@+id/sp_main_sync_content"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_test_main_webdav"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/test_main_connection" />

                <Button
                    android:id="@+id/btn_sync_main_webdav"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/sync_main_webdav" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_restore_main_webdav"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/restore_main_webdav" />

            <Button
                android:id="@+id/btn_convert_main_legacy_backup"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/convert_legacy_backup"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/card_backup_webdav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:id="@+id/row_backup_webdav_title"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/backup_webdav_title"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_backup_webdav_arrow"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="⌄"
                    android:textColor="@color/text_main"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <EditText
                android:id="@+id/et_webdav_backup_url"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/webdav_address_input_hint"
                android:inputType="textUri"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_hint" />

            <EditText
                android:id="@+id/et_webdav_backup_user"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_edit_text"
                android:hint="@string/account_input_hint"
                android:inputType="text"
                android:textColor="@color/text_main"
                android:textColorHint="@color/text_hint" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_webdav_backup_pass"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_edit_text"
                    android:hint="@string/password_input_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/text_main"
                    android:textColorHint="@color/text_hint" />

                <Button
                    android:id="@+id/btn_toggle_backup_webdav_pass"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="6dp"
                    android:contentDescription="@string/click_show_password"
                    android:minWidth="40dp"
                    android:padding="0dp"
                    android:text="@string/show_short" />
            </LinearLayout>

            <Spinner
                android:id="@+id/sp_backup_sync_content"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_test_backup_webdav"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/test_backup_connection" />

                <Button
                    android:id="@+id/btn_sync_backup_webdav"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="@string/sync_backup_webdav" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_restore_backup_webdav"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/restore_backup_webdav" />

            <CheckBox
                android:id="@+id/cb_auto_sync"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/auto_sync_when_open"
                android:textColor="@color/text_main" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/global_sync_settings"
                android:textColor="@color/text_main"
                android:textSize="16sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/webdav_encryption_method"
                    android:textColor="@color/text_main"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/sp_webdav_algorithm"
                    android:layout_width="140dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_edit_text" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_sync"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:text="@string/sync_now" />

            <Button
                android:id="@+id/btn_choose_backup_target"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/choose_backup_target" />

            <Button
                android:id="@+id/btn_backup_history"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:text="@string/cloud_backup" />

            <TextView
                android:id="@+id/tv_last_sync"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/last_upload_never"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_backup_history"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/cloud_backup_hint"
                android:textColor="@color/text_main"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/ll_cloud_backups"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
