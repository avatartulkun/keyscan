<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_random_password_home"
                android:layout_width="64dp"
                android:layout_height="40dp"
                android:contentDescription="@string/home_shortcut_desc"
                android:minWidth="0dp"
                android:padding="0dp"
                android:text="@string/home_shortcut"
                android:textSize="13sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="@string/random_password_title"
                android:textColor="@color/text_main"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/random_password_desc"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_random_password"
            android:layout_width="match_parent"
            android:layout_height="86dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@color/text_main"
            android:textSize="26sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_toggle_password"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/show_password" />

            <Button
                android:id="@+id/btn_copy_password"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/copy" />

            <Button
                android:id="@+id/btn_regenerate_password"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/regenerate" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_length"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/seek_length"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:max="28"
            android:progress="4" />

        <CheckBox
            android:id="@+id/cb_upper"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:checked="true"
            android:text="@string/uppercase_letters"
            android:textColor="@color/text_main" />

        <CheckBox
            android:id="@+id/cb_lower"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:checked="true"
            android:text="@string/lowercase_letters"
            android:textColor="@color/text_main" />

        <CheckBox
            android:id="@+id/cb_digits"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:checked="true"
            android:text="@string/digits"
            android:textColor="@color/text_main" />

        <CheckBox
            android:id="@+id/cb_symbols"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:checked="true"
            android:text="@string/special_symbols"
            android:textColor="@color/text_main" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:text="@string/exclude_confusing_chars"
            android:textColor="@color/text_main"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cb_exclude_zero_o"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="@string/exclude_zero_o"
            android:textColor="@color/text_main" />

        <CheckBox
            android:id="@+id/cb_exclude_one_i"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="@string/exclude_one_i"
            android:textColor="@color/text_main" />

        <CheckBox
            android:id="@+id/cb_exclude_lower_l"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="@string/exclude_lower_l"
            android:textColor="@color/text_main" />

        <ProgressBar
            android:id="@+id/progress_strength"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="14dp"
            android:max="100" />

        <TextView
            android:id="@+id/tv_strength"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:gravity="center_vertical"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_view_generation_history"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:text="@string/view_generation_history" />
    </LinearLayout>
</ScrollView>


