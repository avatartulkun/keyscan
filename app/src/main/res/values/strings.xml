    <string name="about_keyscan">关于 KeyScan</string>
    <string name="about_keyscan_title">KeyScan 密扫</string>
    <string name="about_keyscan_message">安全二维码扫描、生成、密码账本与加密同步工具。\n\n开源地址：\n%1$s\n\n联系方式：\n%2$s</string>
    <string name="help_title">帮助</string>
    <string name="help_features_section_title">功能介绍</string>
    <string name="help_feature_scan_title">扫描二维码</string>
    <string name="help_feature_scan_desc">打开相机实时扫描二维码或条形码。支持自动识别、连续扫描模式，扫描结果可复制、可保存到历史记录。</string>
    <string name="help_feature_album_title">相册导入</string>
    <string name="help_feature_album_desc">从手机相册中选择包含二维码的图片，KeyScan 会自动识别并解析内容，支持保存到历史记录。</string>
    <string name="help_feature_password_title">密码账本</string>
    <string name="help_feature_password_desc">保存你的网站账号和密码，扫码即可自动填充。支持手动添加、自动生成强密码、按网站或账号搜索。所有数据加密存储。</string>
    <string name="help_feature_history_title">历史记录</string>
    <string name="help_feature_history_desc">查看所有扫码和生成二维码的历史记录。支持搜索、编辑、删除，可一键复制内容或转存到密码账本。</string>
    <string name="help_feature_generate_title">生成二维码</string>
    <string name="help_feature_generate_desc">将任意文本或链接生成二维码。支持自定义样式（颜色、圆点、圆角、Logo），可保存到相册或历史记录。</string>
    <string name="help_feature_otp_title">OTP 认证器</string>
    <string name="help_feature_otp_desc">生成动态验证码，支持扫码添加和手动输入密钥。每 30 秒自动刷新，支持一键复制验证码。所有密钥加密存储。</string>
    <string name="help_feature_random_password_title">随机密码生成器</string>
    <string name="help_feature_random_password_desc">生成高强度随机密码，可自定义长度和字符类型（大小写字母、数字、特殊符号）。支持生成历史记录和备注。</string>
    <string name="help_feature_webdav_title">WebDAV 同步</string>
    <string name="help_feature_webdav_desc">将扫码记录、密码账本、OTP 令牌加密备份到 WebDAV 云端。支持主/备双备份通道，换设备时可随时恢复数据。所有数据端到端加密，仅您自己可解密。</string>
    <string name="help_feature_data_insurance_title">数据保险</string>
    <string name="help_feature_data_insurance_desc">查看数据总览（扫码记录、密码账本、OTP 条数）。支持导出加密备份（可选择导出内容）、从备份恢复、验证数据完整性。</string>
    <string name="help_feature_puzzle_title">推推拼图</string>
    <string name="help_feature_puzzle_desc">隐藏小游戏。将数字或图片打乱后拼回原样，支持 3×3 和 4×4 两种模式，可上传自定义图片。</string>
    <string name="help_feature_sokoban_title">推箱子</string>
    <string name="help_feature_sokoban_desc">隐藏小游戏。经典推箱子玩法，共 16 关，从易到难。支持撤回上一步和重置本关。</string>
    <string name="help_webdav_title">☁️ 免费 WebDAV 推荐</string>
    <string name="help_webdav_subtitle">推荐两个完全免费的 WebDAV 服务，建议互为备份</string>
    <string name="help_webdav_jianguoyun_title">坚果云（国内首选）</string>
    <string name="help_webdav_jianguoyun_space">免费空间：每月 1GB 上传流量 + 3GB 下载流量</string>
    <string name="help_webdav_jianguoyun_url">注册地址：https://www.jianguoyun.com</string>
    <string name="help_webdav_jianguoyun_steps">配置步骤：\n1. 注册并登录坚果云\n2. 点击右上角“账户信息” → “安全选项”\n3. 在“第三方应用管理”中点击“添加应用”\n4. 输入“KeyScan”，生成一个应用专用密码（复制保存）\n5. 在 KeyScan 的 WebDAV 设置中填入：\n   服务器地址：https://dav.jianguoyun.com/dav/\n   账号：您的坚果云账号（邮箱）\n   密码：刚才生成的应用专用密码（不是您的登录密码）</string>
    <string name="help_webdav_koofr_title">Koofr（境外备选）</string>
    <string name="help_webdav_koofr_space">免费空间：10GB 永久免费</string>
    <string name="help_webdav_koofr_url">注册地址：https://koofr.eu</string>
    <string name="help_webdav_koofr_steps">配置步骤：\n1. 注册并登录 Koofr\n2. 在网页右上角点击“设置” → “密码”\n3. 在“应用密码”中生成一个新密码（复制保存）\n4. 在 KeyScan 的 WebDAV 设置中填入：\n   服务器地址：https://app.koofr.net/dav/\n   账号：您的 Koofr 账号（邮箱）\n   密码：刚才生成的应用专用密码</string>
    <string name="help_webdav_recommended_title">建议配置方式</string>
    <string name="help_webdav_recommended_body">1. 主 WebDAV 配置为坚果云\n2. 备用备份 WebDAV 配置为 Koofr\n3. 配置完成后点击“立即同步”即可上传加密数据</string>
