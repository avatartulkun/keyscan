    <string name="about_keyscan">About KeyScan</string>
    <string name="about_keyscan_title">KeyScan</string>
    <string name="about_keyscan_message">A secure QR scanner, QR generator, password ledger, and encrypted sync tool.\n\nOpen source:\n%1$s\n\nContact:\n%2$s</string>
    <string name="help_title">Help</string>
    <string name="help_features_section_title">Feature Guide</string>
    <string name="help_feature_scan_title">Scan QR codes</string>
    <string name="help_feature_scan_desc">Open the camera to scan QR codes or barcodes in real time. Supports automatic recognition and continuous scanning. Results can be copied and saved to history.</string>
    <string name="help_feature_album_title">Album Import</string>
    <string name="help_feature_album_desc">Choose an image that contains a QR code from your phone album. KeyScan recognizes and parses it automatically, and can save it to history.</string>
    <string name="help_feature_password_title">Password Ledger</string>
    <string name="help_feature_password_desc">Save website accounts and passwords, then fill them by scanning. Supports manual entries, strong password generation, and search by website or account. All data is stored encrypted.</string>
    <string name="help_feature_history_title">History</string>
    <string name="help_feature_history_desc">View all scanning and QR generation history. Supports search, edit, and delete, plus one-tap copy or saving content into the password ledger.</string>
    <string name="help_feature_generate_title">Generate QR codes</string>
    <string name="help_feature_generate_desc">Turn any text or link into a QR code. Supports custom styles such as colors, dots, rounded corners, and logo, and can save to the album or history.</string>
    <string name="help_feature_otp_title">OTP Authenticator</string>
    <string name="help_feature_otp_desc">Generate time-based verification codes, add tokens by QR scan or manual secret, refresh every 30 seconds, and copy codes with one tap. All secrets are stored encrypted.</string>
    <string name="help_feature_random_password_title">Random Password Generator</string>
    <string name="help_feature_random_password_desc">Generate strong random passwords with customizable length and character types, including uppercase, lowercase, numbers, and symbols. Supports generation history and notes.</string>
    <string name="help_feature_webdav_title">WebDAV Sync</string>
    <string name="help_feature_webdav_desc">Encrypt and back up scan records, password ledger entries, and OTP tokens to WebDAV cloud storage. Supports primary and backup channels so data can be restored on another device. All data is end-to-end encrypted and can only be decrypted by you.</string>
    <string name="help_feature_data_insurance_title">Data Insurance</string>
    <string name="help_feature_data_insurance_desc">Review the data overview, including scan records, password ledger entries, and OTP token counts. Supports encrypted export with selectable content, restore from backup, and data integrity checks.</string>
    <string name="help_feature_puzzle_title">Sliding Puzzle</string>
    <string name="help_feature_puzzle_desc">A hidden mini game. Shuffle numbers or an image and restore the original layout. Supports 3×3 and 4×4 modes, plus custom image upload.</string>
    <string name="help_feature_sokoban_title">Sokoban</string>
    <string name="help_feature_sokoban_desc">A hidden mini game with classic Sokoban gameplay. Includes 16 levels from easy to hard, with undo and reset support.</string>
    <string name="help_webdav_title">☁️ Free WebDAV Recommendations</string>
    <string name="help_webdav_subtitle">Two free WebDAV services are recommended as backups for each other</string>
    <string name="help_webdav_jianguoyun_title">Nutstore (recommended in mainland China)</string>
    <string name="help_webdav_jianguoyun_space">Free plan: 1GB monthly upload traffic + 3GB monthly download traffic</string>
    <string name="help_webdav_jianguoyun_url">Sign up: https://www.jianguoyun.com</string>
    <string name="help_webdav_jianguoyun_steps">Setup steps:\n1. Sign up and sign in to Nutstore\n2. Click “Account Info” → “Security Options” in the top-right corner\n3. In “Third-party App Management”, click “Add App”\n4. Enter “KeyScan” and generate an app-specific password, then copy and save it\n5. Sign in to the Nutstore web app and create a folder named keyscan in the root directory, or use another folder name you prefer\n   In the KeyScan WebDAV address field, enter:\n   https://dav.jianguoyun.com/dav/keyscan\n   Note: the address must end with /keyscan, or the folder name you created\n6. In KeyScan WebDAV settings, enter:\n   Server URL: https://dav.jianguoyun.com/dav/keyscan\n   Account: your Nutstore account email\n   Password: the app-specific password you just generated, not your login password</string>
    <string name="help_webdav_koofr_title">Koofr (accessible backup option)</string>
    <string name="help_webdav_koofr_space">Free plan: 10GB forever free</string>
    <string name="help_webdav_koofr_url">Sign up (accessible in mainland China): https://koofr.eu/</string>
    <string name="help_webdav_koofr_steps">Setup steps:\n1. Sign up and sign in to Koofr\n2. Click “Settings” → “Password” in the top-right corner\n3. Generate a new password under “App Passwords”, then copy and save it\n4. In KeyScan WebDAV settings, enter:\n   Server URL: https://app.koofr.net/dav/koofr\n   Account: your Koofr account email\n   Password: the app-specific password you just generated</string>
    <string name="help_webdav_recommended_title">Recommended setup</string>
    <string name="help_webdav_recommended_body">1. Set primary WebDAV to Nutstore\n2. Set backup WebDAV to Koofr\n3. After setup, tap “Sync now” to upload encrypted data</string>
